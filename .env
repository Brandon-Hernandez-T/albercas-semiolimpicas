# Copia este archivo a `.env` y ajusta los valores (python-dotenv los carga al arrancar Django).
#
# Migraciones (después de configurar la base y activar el venv):
#   python manage.py migrate
#
# Si PostgreSQL aún no existe, créala antes (ej. `createdb albercas_semiolimpicas` o desde tu panel).

# --- Base de datos PostgreSQL ---
export DB_NAME='albercas_db'
export DB_USER=''
export DB_PASSWORD=''
export DB_HOST='localhost'
export DB_PORT=5432

# --- Django ---
# En producción: DEBUG=False y SECRET_KEY obligatoria (cadena larga y aleatoria).
DEBUG=True
SECRET_KEY=cambia-esto-en-desarrollo-o-genera-una-clave-segura

# Lista separada por comas, sin espacios obligatorios (ej. ejemplo.com,www.ejemplo.com)
ALLOWED_HOSTS=localhost,127.0.0.1

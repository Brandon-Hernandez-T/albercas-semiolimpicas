# Copia este archivo a `.env` y ajusta los valores (python-dotenv los carga al arrancar Django).
#
# Migraciones (después de configurar la base y activar el venv):
#   python manage.py migrate
#
# Si PostgreSQL aún no existe, créala antes (ej. `createdb albercas_semiolimpicas` o desde tu panel).

# --- Base de datos PostgreSQL ---
DB_NAME=albercas_semiolimpicas
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
# Segundos de reutilización de conexión (0 en dev; 60 recomendado en producción).
DB_CONN_MAX_AGE=0

# --- Django ---
# En producción: DEBUG=False y SECRET_KEY obligatoria (cadena larga y aleatoria).
DEBUG=True
SECRET_KEY=cambia-esto-en-desarrollo-o-genera-una-clave-segura

# Lista separada por comas, sin espacios obligatorios (ej. ejemplo.com,www.ejemplo.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Producción / Fase 6 (solo relevante con DEBUG=False) ---
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=0
# SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# SECURE_HSTS_PRELOAD=False
# LOG_LEVEL=INFO

# --- Gunicorn (opcional) ---
# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=30
